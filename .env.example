# ── Django ─────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True

# ── Database ───────────────────────────────────────────────────────────────────
# Leave empty locally to use SQLite. On Render this is auto-set from the DB.
DATABASE_URL=

# ── Admin Superuser (used by build.sh on first deploy) ────────────────────────
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=your_strong_password_here

# ── Cloudinary (persistent image/file storage for Render) ─────────────────────
# Free account at cloudinary.com → Dashboard → copy "API Environment variable"
# Looks like: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=cloudinary://xxxxx:yyyyy@zzzzz

# ── Gmail SMTP ─────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_gmail@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
CONTACT_RECEIVER_EMAIL=your_gmail@gmail.com
